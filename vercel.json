{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://YOUR-RENDER-APP.onrender.com/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Forwarded-Proto",
          "value": "https"
        }
      ]
    }
  ]
}
